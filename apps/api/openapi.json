{
  "openapi": "3.1.0",
  "info": {
    "title": "Hono Poc API",
    "version": "0.0.0"
  },
  "tags": [
    {
      "name": "Authors",
      "description": "著者"
    },
    {
      "name": "Books",
      "description": "書籍"
    }
  ],
  "components": {
    "schemas": {
      "CreateAuthorResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "作成した著者のID"
          }
        },
        "required": [
          "id"
        ],
        "description": "著者の作成結果"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            },
            "minItems": 1,
            "description": "エラー一覧"
          }
        },
        "required": [
          "errors"
        ],
        "description": "エラーレスポンス"
      },
      "ErrorDetail": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "対象フィールド"
          },
          "message": {
            "type": "string",
            "description": "エラーメッセージ"
          }
        },
        "required": [
          "message"
        ],
        "description": "エラー詳細"
      },
      "AuthorList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Author"
            },
            "description": "著者の一覧"
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "required": [
          "items",
          "pagination"
        ],
        "description": "著者一覧のレスポンス"
      },
      "Author": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "著者ID"
          },
          "name": {
            "type": "string",
            "description": "著者名"
          },
          "version": {
            "type": "integer",
            "description": "バージョン"
          }
        },
        "required": [
          "id",
          "name",
          "version"
        ],
        "description": "著者"
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "description": "現在のページ番号"
          },
          "perPage": {
            "type": "integer",
            "description": "1 ページあたりの件数"
          },
          "total": {
            "type": "integer",
            "description": "総件数"
          },
          "totalPages": {
            "type": "integer",
            "description": "総ページ数"
          }
        },
        "required": [
          "page",
          "perPage",
          "total",
          "totalPages"
        ],
        "description": "ページネーションのメタ情報"
      },
      "CreateBookResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "作成した書籍のID"
          }
        },
        "required": [
          "id"
        ],
        "description": "書籍の作成結果"
      },
      "BookList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Book"
            },
            "description": "書籍の一覧"
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "required": [
          "items",
          "pagination"
        ],
        "description": "書籍一覧のレスポンス"
      },
      "Book": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "書籍ID"
          },
          "title": {
            "type": "string",
            "description": "書籍タイトル"
          },
          "authors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthorSummary"
            },
            "description": "著者の一覧"
          },
          "version": {
            "type": "integer",
            "description": "バージョン"
          }
        },
        "required": [
          "id",
          "title",
          "authors",
          "version"
        ],
        "description": "書籍"
      },
      "AuthorSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "著者ID"
          },
          "name": {
            "type": "string",
            "description": "著者名"
          }
        },
        "required": [
          "id",
          "name"
        ],
        "description": "著者の要約"
      }
    },
    "parameters": {}
  },
  "paths": {
    "/authors": {
      "post": {
        "tags": [
          "Authors"
        ],
        "summary": "著者を作成",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "description": "著者名"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "作成した著者の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAuthorResult"
                }
              }
            }
          },
          "422": {
            "description": "リクエストボディが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Authors"
        ],
        "summary": "著者一覧を取得",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "ページ番号",
              "example": 1
            },
            "required": false,
            "description": "ページ番号",
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "description": "1 ページあたりの件数",
              "example": 10
            },
            "required": false,
            "description": "1 ページあたりの件数",
            "name": "perPage",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "著者の一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorList"
                }
              }
            }
          },
          "400": {
            "description": "クエリパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/authors/{id}": {
      "get": {
        "tags": [
          "Authors"
        ],
        "summary": "著者を取得",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "著者ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "著者ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "著者の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Author"
                }
              }
            }
          },
          "400": {
            "description": "パスパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "著者が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Authors"
        ],
        "summary": "著者を更新",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "著者ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "著者ID",
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "description": "著者名"
                  },
                  "version": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "バージョン"
                  }
                },
                "required": [
                  "name",
                  "version"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新後の著者の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Author"
                }
              }
            }
          },
          "400": {
            "description": "パスパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "著者が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "バージョンが競合",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "リクエストボディが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Authors"
        ],
        "summary": "著者を削除",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "著者ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "著者ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "削除完了"
          },
          "400": {
            "description": "パスパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "著者が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "著者が書籍に割り当てられている",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/books": {
      "post": {
        "tags": [
          "Books"
        ],
        "summary": "書籍を作成",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200,
                    "description": "書籍タイトル"
                  },
                  "authorIds": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "minItems": 1,
                    "maxItems": 10,
                    "description": "著者IDの一覧"
                  }
                },
                "required": [
                  "title",
                  "authorIds"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "作成した書籍の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateBookResult"
                }
              }
            }
          },
          "400": {
            "description": "著者が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "リクエストボディが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Books"
        ],
        "summary": "書籍一覧を取得",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "ページ番号",
              "example": 1
            },
            "required": false,
            "description": "ページ番号",
            "name": "page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "description": "1 ページあたりの件数",
              "example": 10
            },
            "required": false,
            "description": "1 ページあたりの件数",
            "name": "perPage",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "書籍の一覧",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookList"
                }
              }
            }
          },
          "400": {
            "description": "クエリパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/books/{id}": {
      "get": {
        "tags": [
          "Books"
        ],
        "summary": "書籍を取得",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "書籍ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "書籍ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "書籍の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Book"
                }
              }
            }
          },
          "400": {
            "description": "パスパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "書籍が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Books"
        ],
        "summary": "書籍を更新",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "書籍ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "書籍ID",
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 200,
                    "description": "書籍タイトル"
                  },
                  "authorIds": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "minItems": 1,
                    "maxItems": 10,
                    "description": "著者IDの一覧"
                  },
                  "version": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "バージョン"
                  }
                },
                "required": [
                  "title",
                  "authorIds",
                  "version"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新後の書籍の情報",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Book"
                }
              }
            }
          },
          "400": {
            "description": "パスパラメータが不正、または著者が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "書籍が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "バージョンが競合",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "リクエストボディが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Books"
        ],
        "summary": "書籍を削除",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "書籍ID",
              "example": "01920000-0000-7000-8000-000000000001"
            },
            "required": true,
            "description": "書籍ID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "削除完了"
          },
          "400": {
            "description": "パスパラメータが不正",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "書籍が存在しない",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
