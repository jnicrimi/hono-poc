{
  "name": "@hono-poc/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --reporter=dot --coverage",
    "test:unit": "vitest run --reporter=dot --project unit",
    "test:integration": "vitest run --reporter=dot --project integration",
    "test:api": "vitest run --reporter=dot --project api",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "@hono/zod-openapi": "1.4.0",
    "@scalar/hono-api-reference": "0.11.8",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.27",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@hono-poc/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.0",
    "vitest": "4.1.9"
  }
}
