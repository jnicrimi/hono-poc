{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "NODE_ENV",
        "PORT",
        "LOG_LEVEL",
        "DATABASE_URL",
        "BODY_LIMIT_BYTES",
        "REQUEST_TIMEOUT_MS",
        "DB_POOL_MAX",
        "DB_POOL_IDLE_TIMEOUT_SEC",
        "DB_POOL_CONNECT_TIMEOUT_SEC",
        "DB_POOL_MAX_LIFETIME_SEC",
        "SHUTDOWN_TIMEOUT_MS"
      ]
    }
  }
}
