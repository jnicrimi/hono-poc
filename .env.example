# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# HTTP boundary (BODY_LIMIT_BYTES=1MB / REQUEST_TIMEOUT_MS=30s)
BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=30000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Web
VITE_API_URL=http://localhost:3000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?sslmode=disable
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_SEC=30
DB_POOL_CONNECT_TIMEOUT_SEC=10
DB_POOL_MAX_LIFETIME_SEC=1800

# Graceful shutdown
SHUTDOWN_TIMEOUT_MS=10000
